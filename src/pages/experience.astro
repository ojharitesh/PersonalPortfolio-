---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteNav from "../components/SiteNav.astro";
import Prism from "../components/Prism";

const workExperience = [
    {
        role: "Head Resident Advisor",
        org: "Residential Life, Allegheny College",
        date: "Aug 2025 - Present",
        summary:
            "Supervise and mentor 3 Resident Advisors while overseeing community development and resident support for a building of 70+ residents.",
        bullets: [
            "Planned and executed 12+ annual programs, increasing engagement by 15%.",
            "Led conflict resolution efforts to maintain an inclusive and safe living environment.",
        ],
    },
    {
        role: "Information Technology Office Assistant",
        org: "Information Technology Department, Allegheny College",
        date: "Sep 2024 - Present",
        summary:
            "Provided first-line technical support for campus users and helped diagnose a wide range of device and connectivity issues.",
        bullets: [
            "Resolved 50+ student technical issues related to macOS, Windows, and network connectivity.",
            "Improved system reliability and student satisfaction through responsive ticket handling.",
        ],
    },
    {
        role: "Teaching Assistant",
        org: "CIS Department, Allegheny College",
        date: "Jan 2025 - Present",
        summary:
            "Supported students in understanding technical concepts, project requirements, and assignment workflows.",
        bullets: [
            "Guided 20+ students through course material and project expectations.",
            "Held office hours and appointments to help students work through class problems.",
        ],
    },
    {
        role: "Fellow Leader",
        org: "Code with Chompers, Allegheny College",
        date: "Jan 2025 - Present",
        summary:
            "Coordinated lesson plans and led volunteers delivering computational activities for local students.",
        bullets: [
            "Led a team of 5 volunteers to improve STEM engagement by 20% for 70+ students.",
            "Built an engaging environment where kids could explore programming and problem-solving.",
        ],
    },
];

const education = {
    school: "Allegheny College",
    location: "Meadville, PA",
    graduation: "Expected May 2028",
    degree: "B.S. in Computer Science & Economics",
    gpa: "3.92 / 4.0",
    minor: "Mathematics",
    coursework: [
        "Data Exploration",
        "Macroeconomic Theory",
        "Operating Systems",
        "Data Structures",
        "Theoretical Machines",
        "Calculus I & II",
        "iOS Development (CodePath)",
    ],
};

const honors = [
    "Best Beginners Award, Gatorverse Hackathon 2025",
    "Distinguished Alden Scholar Dean's List",
    "First Prize, ACM x UPE Afternoon of Code Mini-Hackathon",
    "Upsilon Pi Epsilon Honor Society",
    "Lambda Sigma Honor Society",
];

const organizations = [
    "Association for Computational Computing (ACM) - Dec 2024 to Present",
    "Honor Committee - Mar 2025 to Present",
    "South Asian Student Society - Apr 2025 to Present",
    "Association of Asian and Asian American Awareness (A5) - Jan 2025 to Present",
];
---

<BaseLayout title="Experience — Ritesh Ojha">
<Prism
    client:only="react"
    animationType="rotate"
    glow={1.2}
    noise={0.25}
    bloom={1.1}
    transition:persist
/>
<SiteNav active="experience" transition:persist />

<main class="experience-page" transition:animate="fade">
    <section class="hero-shell">
        <div class="hero-copy">
            <p class="eyebrow">Resume snapshot</p>
            <h1>Experience</h1>
            <p class="hero-summary">
                Computer Science and Economics student at Allegheny College with
                campus leadership, technical support, teaching, and
                product-building experience.
            </p>
            <div class="hero-links">
                <a
                    class="hero-link hero-link--primary"
                    href="/resume.pdf"
                    target="_blank"
                    rel="noreferrer noopener">Open Resume</a
                >
                <a
                    class="hero-link hero-link--secondary"
                    href="mailto:ojha01@allegheny.edu">Contact</a
                >
            </div>
        </div>

        <div class="hero-card hero-card--info">
            <div class="info-row">
                <span class="info-label">Name</span>
                <span class="info-value">Ritesh Ojha</span>
            </div>
            <div class="info-row">
                <span class="info-label">Phone</span>
                <span class="info-value">(443)-729-6002</span>
            </div>
            <div class="info-row">
                <span class="info-label">Email</span>
                <span class="info-value">ojha01@allegheny.edu</span>
            </div>
            <div class="info-row">
                <span class="info-label">GitHub</span>
                <span class="info-value">github.com/ojharitesh</span>
            </div>
            <div class="info-row">
                <span class="info-label">Graduation</span>
                <span class="info-value">May 2028</span>
            </div>
        </div>
    </section>

    <section class="content-grid">
        <div class="main-column">
            <section class="panel">
                <div class="section-heading">
                    <p class="section-kicker">Work Experience</p>
                    <h2>Leadership, support, and teaching</h2>
                </div>

                <div class="timeline">
                    {
                        workExperience.map((job) => (
                            <article class="timeline-card">
                                <div class="timeline-header">
                                    <div>
                                        <h3>{job.role}</h3>
                                        <p class="timeline-meta">{job.org}</p>
                                    </div>
                                    <span class="timeline-date">
                                        {job.date}
                                    </span>
                                </div>
                                <p class="timeline-summary">{job.summary}</p>
                                <ul class="bullet-list">
                                    {job.bullets.map((bullet) => (
                                        <li>{bullet}</li>
                                    ))}
                                </ul>
                            </article>
                        ))
                    }
                </div>
            </section>
        </div>

        <aside class="side-column">
            <section class="panel side-panel">
                <div class="section-heading">
                    <p class="section-kicker">Education</p>
                    <h2>Allegheny College</h2>
                </div>

                <div class="stack">
                    <div class="detail-row">
                        <span class="info-label">Location</span>
                        <span class="info-value">{education.location}</span>
                    </div>
                    <div class="detail-row">
                        <span class="info-label">Graduation</span>
                        <span class="info-value">{education.graduation}</span>
                    </div>
                    <div class="detail-row">
                        <span class="info-label">Degree</span>
                        <span class="info-value">{education.degree}</span>
                    </div>
                    <div class="detail-row">
                        <span class="info-label">GPA</span>
                        <span class="info-value">{education.gpa}</span>
                    </div>
                    <div class="detail-row">
                        <span class="info-label">Minor</span>
                        <span class="info-value">{education.minor}</span>
                    </div>
                </div>

                <div class="mini-block">
                    <p class="mini-title">Relevant Coursework</p>
                    <div class="chip-list">
                        {
                            education.coursework.map((item) => (
                                <span class="chip">{item}</span>
                            ))
                        }
                    </div>
                </div>
            </section>

            <section class="panel side-panel">
                <div class="section-heading">
                    <p class="section-kicker">Honors</p>
                    <h2>Awards and recognition</h2>
                </div>
                <ul class="bullet-list compact-list">
                    {honors.map((honor) => <li>{honor}</li>)}
                </ul>
            </section>

            <section class="panel side-panel">
                <div class="section-heading">
                    <p class="section-kicker">Organizations</p>
                    <h2>Involved on campus</h2>
                </div>
                <ul class="bullet-list compact-list">
                    {
                        organizations.map((organization) => (
                            <li>{organization}</li>
                        ))
                    }
                </ul>
            </section>
        </aside>
    </section>
</main>
</BaseLayout>

<style>
    .experience-page {
        position: relative;
        width: 100%;
        min-height: 100vh;
        padding: 7rem 1.5rem 3rem;
        overflow-x: hidden;
    }

    .hero-shell,
    .content-grid {
        width: 100%;
        max-width: 1180px;
        margin: 0 auto;
    }

    .hero-shell {
        display: grid;
        grid-template-columns: minmax(0, 1.7fr) minmax(280px, 0.9fr);
        gap: 1rem;
        align-items: stretch;
        margin-bottom: 1rem;
    }

    .hero-copy,
    .hero-card,
    .panel {
        border: 1px solid rgba(255, 255, 255, 0.12);
        background:
            radial-gradient(
                circle at top left,
                rgba(255, 255, 255, 0.08),
                transparent 38%
            ),
            rgba(8, 10, 14, 0.72);
        box-shadow: 0 30px 80px rgba(0, 0, 0, 0.35);
        backdrop-filter: blur(18px);
    }

    .hero-copy {
        border-radius: 32px;
        padding: clamp(1.5rem, 3.8vw, 3rem);
    }

    .hero-card {
        border-radius: 32px;
        padding: clamp(1.25rem, 3vw, 2rem);
        display: grid;
        gap: 0.9rem;
        align-content: start;
    }

    .eyebrow,
    .section-kicker {
        margin: 0 0 0.8rem;
        color: rgba(242, 245, 247, 0.72);
        text-transform: uppercase;
        letter-spacing: 0.18em;
        font-size: 0.78rem;
    }

    h1,
    h2,
    h3,
    p {
        margin-top: 0;
    }

    h1 {
        margin-bottom: 1rem;
        font-size: clamp(2.8rem, 6vw, 5.2rem);
        line-height: 0.94;
        letter-spacing: -0.05em;
    }

    .hero-summary {
        margin: 0;
        max-width: 62ch;
        color: rgba(242, 245, 247, 0.82);
        font-size: clamp(1rem, 1.55vw, 1.15rem);
        line-height: 1.65;
    }

    .hero-links {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-top: 1.4rem;
    }

    .hero-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 9.5rem;
        padding: 0.72rem 1rem;
        border-radius: 999px;
        text-decoration: none;
        transition:
            transform 160ms ease,
            background-color 160ms ease,
            border-color 160ms ease,
            color 160ms ease;
        font-size: 0.92rem;
    }

    .hero-link--primary {
        background: rgba(248, 251, 255, 0.95);
        color: #0b0d10;
        border: 1px solid rgba(255, 255, 255, 0.55);
    }

    .hero-link--secondary {
        background: rgba(8, 12, 16, 0.58);
        color: rgba(242, 245, 247, 0.88);
        border: 1px solid rgba(255, 255, 255, 0.22);
    }

    .hero-link:hover,
    .hero-link:focus-visible {
        transform: translateY(-1px);
        outline: none;
    }

    .info-row,
    .detail-row {
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
        padding: 0.85rem 0;
        border-top: 1px solid rgba(255, 255, 255, 0.08);
    }

    .hero-card .info-row:first-of-type,
    .side-panel .detail-row:first-of-type {
        border-top: 0;
        padding-top: 0;
    }

    .info-label,
    .timeline-meta,
    .timeline-date {
        color: rgba(242, 245, 247, 0.68);
        font-size: 0.84rem;
        letter-spacing: 0.03em;
        text-transform: uppercase;
    }

    .info-value {
        color: rgba(248, 251, 255, 0.98);
        font-size: 1rem;
        line-height: 1.45;
    }

    .content-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.55fr) minmax(300px, 0.95fr);
        gap: 1rem;
        align-items: start;
    }

    .main-column,
    .side-column {
        display: grid;
        gap: 1rem;
    }

    .panel {
        border-radius: 28px;
        padding: clamp(1.2rem, 2.8vw, 2rem);
    }

    .section-heading {
        margin-bottom: 1.2rem;
    }

    .section-heading h2 {
        margin: 0;
        font-size: clamp(1.3rem, 2.2vw, 1.75rem);
        letter-spacing: -0.03em;
    }

    .timeline,
    .stack,
    .mini-block {
        display: grid;
        gap: 0.9rem;
    }

    .timeline-card {
        padding: 1.15rem 1.1rem;
        border-radius: 22px;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.09);
    }

    .timeline-header {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: start;
        margin-bottom: 0.85rem;
    }

    .timeline-header h3 {
        margin: 0;
        font-size: 1.1rem;
        letter-spacing: -0.02em;
    }

    .timeline-summary {
        margin: 0 0 0.85rem;
        color: rgba(242, 245, 247, 0.84);
        line-height: 1.6;
    }

    .bullet-list {
        margin: 0;
        padding-left: 1.1rem;
        display: grid;
        gap: 0.5rem;
        color: rgba(242, 245, 247, 0.82);
        line-height: 1.55;
    }

    .compact-list {
        gap: 0.65rem;
    }

    .chip-list {
        display: flex;
        flex-wrap: wrap;
        gap: 0.55rem;
    }

    .chip {
        padding: 0.48rem 0.75rem;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.12);
        color: rgba(248, 251, 255, 0.9);
        font-size: 0.84rem;
        line-height: 1;
    }

    .mini-title {
        margin: 0 0 0.8rem;
        color: rgba(242, 245, 247, 0.72);
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-size: 0.76rem;
    }

    @media (max-width: 960px) {
        .hero-shell,
        .content-grid {
            grid-template-columns: 1fr;
        }
    }

    @media (max-width: 700px) {
        .experience-page {
            padding: 5.5rem 1rem 2.5rem;
        }

        .hero-copy,
        .hero-card,
        .panel {
            border-radius: 22px;
        }

        .timeline-header {
            flex-direction: column;
            gap: 0.4rem;
        }

        .timeline-date {
            font-size: 0.75rem;
        }

        .hero-link {
            width: 100%;
            justify-content: center;
        }

        h1 {
            font-size: clamp(2rem, 8vw, 3rem);
        }

        .hero-summary {
            font-size: 0.92rem;
        }
    }

    @media (max-width: 480px) {
        .experience-page {
            padding: 5rem 0.85rem 2rem;
        }

        .hero-copy,
        .hero-card,
        .panel {
            border-radius: 18px;
            padding: 1rem;
        }

        h1 {
            font-size: 1.8rem;
            margin-bottom: 0.75rem;
        }

        .hero-summary {
            font-size: 0.86rem;
            line-height: 1.55;
        }

        .timeline-card {
            padding: 0.9rem 0.85rem;
            border-radius: 16px;
        }

        .timeline-header h3 {
            font-size: 0.98rem;
        }

        .timeline-summary {
            font-size: 0.88rem;
        }

        .bullet-list {
            font-size: 0.86rem;
            padding-left: 0.9rem;
        }

        .chip {
            padding: 0.4rem 0.6rem;
            font-size: 0.78rem;
        }

        .section-heading h2 {
            font-size: 1.15rem;
        }

        .info-value {
            font-size: 0.92rem;
        }

        .hero-links {
            flex-direction: column;
        }

        .hero-link {
            min-width: unset;
            padding: 0.65rem 0.9rem;
            font-size: 0.86rem;
        }
    }

    @media (max-width: 380px) {
        .experience-page {
            padding: 4.5rem 0.65rem 1.5rem;
        }

        h1 {
            font-size: 1.55rem;
        }

        .hero-copy,
        .hero-card,
        .panel {
            padding: 0.85rem;
        }

        .timeline-card {
            padding: 0.75rem 0.7rem;
        }
    }
</style>

