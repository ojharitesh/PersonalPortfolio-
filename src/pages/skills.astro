---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionPage from "../components/SectionPage.astro";
import Prism from "../components/Prism";

const technicalSkills = [
    "Swift",
    "Python",
    "SQL",
    "PyTorch",
    "Scikit-learn",
    "MongoDB",
    "Supabase",
    "JavaScript",
    "React",
    "Vercel",
    "HTML/CSS",
    "Jupyter Notebook",
    "Git",
    "VS Code",
    "Data Analysis & Visualization",
    "UI/UX Design",
    "Technical Documentation",
    "SEO",
    "macOS",
    "Microsoft Office (Excel, Word, PowerPoint, Outlook)",
    "Data Structures",
    "Agile Methodologies",
    "DevOps",
    "Machine Learning",
];

const professionalSkills = [
    "First-line IT support",
    "System setup & configuration",
    "Asset & inventory management",
    "Data security & confidentiality",
    "Basic networking concepts",
    "Project management",
];
---

<BaseLayout title="Skills — Ritesh Ojha">
<Prism
    client:only="react"
    animationType="rotate"
    glow={1.2}
    noise={0.25}
    bloom={1.1}
    transition:persist
/>

<SectionPage active="skills" title="Skills" subtitle="Tools and strengths">
    <p>
        A quick view of the technical and professional skills I use in product
        development, data work, and team collaboration.
    </p>

    <h2>Technical Skills</h2>
    <div class="skills-grid">
        {
            technicalSkills.map((skill) => (
                <span class="skill-chip">{skill}</span>
            ))
        }
    </div>

    <h2>Professional Skills</h2>
    <div class="skills-grid">
        {
            professionalSkills.map((skill) => (
                <span class="skill-chip">{skill}</span>
            ))
        }
    </div>
</SectionPage>
</BaseLayout>

<style>
    .skills-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 0.55rem;
    }

    .skill-chip {
        padding: 0.5rem 0.8rem;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.14);
        color: rgba(248, 251, 255, 0.92);
        font-size: 0.86rem;
        line-height: 1;
    }

    h2 {
        margin: 0.25rem 0 0.7rem;
        font-size: clamp(1.1rem, 2vw, 1.35rem);
        letter-spacing: -0.02em;
        color: rgba(248, 251, 255, 0.98);
    }
</style>

